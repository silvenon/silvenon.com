{
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "module": "Preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "vitest/globals", "@remix-run/node"],
    "typeRoots": ["./node_modules", "./node_modules/@types", "./typings"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
    },
  },
  "ts-node": {
    "transpileOnly": true,
  },
 "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx"
  ],
  "exclude": ["node_modules", "./integration", "./app/posts"],
}
