{
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true,
    "module": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
  },
  "exclude": [
    "../node_modules/@types/jest",
    "../node_modules/@testing-library/jest-dom"
  ],
  "include": [
    "**/*.ts",
  ],
}
