{
  "name": "silvenon.com",
  "description": "My personal website",
  "homepage": "https://silvenon.com",
  "author": {
    "name": "Matija Marohnić",
    "email": "matija.marohnic@gmail.com",
    "url": "https://silvenon.com"
  },
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvenon/silvenon.com.git"
  },
  "license": "MIT",
  "scripts": {
    "setup": "npm install && lefthook run setup",
    "generate:posts": "node --no-warnings --loader ts-node/esm scripts/compile-posts.ts",
    "generate:icons": "node --no-warnings --loader ts-node/esm scripts/bundle-icons.ts",
    "pre:posts": "cross-env NODE_ENV=production npm run generate:posts",
    "dev": "run-s -l pre:posts && run-p -l dev:*",
    "dev:posts": "cross-env NODE_ENV=development npm run generate:posts",
    "dev:remix": "remix vite:dev",
    "build": "run-p build:posts build:remix",
    "build:posts": "cross-env NODE_ENV=production npm run generate:posts",
    "build:remix": "remix vite:build",
    "deploy": "fly deploy --remote-only",
    "start": "remix-serve build",
    "lint:check-config": "eslint-config-prettier app/root.tsx posts/__tests__/posts.test.ts",
    "lint": "eslint . --report-unused-disable-directives --cache --cache-location ./node_modules/.cache/eslint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "lefthook run typecheck",
    "validate": "run-p test lint:check-config lint typecheck"
  },
  "dependencies": {
    "@gitgraph/react": "^1.6.0",
    "@heroicons/react": "^2.1.1",
    "@react-hook/media-query": "^1.1.1",
    "@remix-run/node": "^2.8.1",
    "@remix-run/react": "^2.8.1",
    "@remix-run/serve": "^2.8.1",
    "cloudinary-tiny-js": "^2.1.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.5.0",
    "feed": "^4.2.2",
    "isbot": "^5.1.1",
    "mdx-bundler": "^10.0.1",
    "metronome-sh": "^8.2.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "tiny-invariant": "^1.3.3",
    "toml": "^3.0.0",
    "utterances-react-component": "^1.0.0"
  },
  "devDependencies": {
    "@gitgraph/core": "^1.5.0",
    "@mdx-js/rollup": "^3.0.1",
    "@playwright/test": "^1.42.1",
    "@remix-run/dev": "^2.8.1",
    "@remix-run/testing": "^2.8.1",
    "@tailwindcss/aspect-ratio": "^0.4.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/cacache": "^17.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/hast": "^3.0.4",
    "@types/node": "^18.19.24",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "binode": "^1.0.5",
    "cacache": "^17.1.4",
    "chokidar": "^3.6.0",
    "cloudinary": "^2.0.3",
    "cross-env": "^7.0.3",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "happy-dom": "^13.9.0",
    "lefthook": "^1.6.7",
    "node-html-parser": "^6.1.12",
    "postcss": "^8.4.36",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.12",
    "rehype-pretty-code": "^0.13.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^4.0.0",
    "remark-smartypants": "^2.1.0",
    "remark-unwrap-images": "^4.0.0",
    "shiki": "^1.2.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.1.6",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.4.0"
  },
  "overrides": {
    "utterances-react-component": {
      "exports": {
        ".": {
          "require": "./dist/index.cjs.js",
          "import": "./dist/index.es.js",
          "types": "./dist/index.d.ts"
        }
      }
    }
  }
}
